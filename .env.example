# Ollama runs on the host by default. For native development use localhost.
OLLAMA_BASE_URL=http://host.docker.internal:11434
DEFAULT_OLLAMA_MODEL=qwen3-vl:4b

# Leave empty when Gemini is not used.
GEMINI_API_KEY=
DEFAULT_GEMINI_MODEL=gemini-3.5-flash

MODEL_TIMEOUT_SECONDS=60
RTSP_STALL_TIMEOUT_SECONDS=30
HISTORY_MAX_BYTES=1073741824
MAX_INFANTS=1
MAX_ADULTS=4

# Temporal stabilization is applied only to validated VLM structured outputs.
STABILITY_WINDOW_SIZE=5
STABILITY_CONFIRMATION_FRAMES=3
STABILITY_CLEAR_FRAMES=3
STABILITY_BOX_IOU_THRESHOLD=0.2
STABILITY_BOX_EMA_ALPHA=0.35
STABILITY_TIMELINE_MAX_POINTS=500

FFMPEG_BINARY=ffmpeg
